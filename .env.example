# tidx environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# To use it locally with `cargo run`, export the vars:
#   set -a && source .env && set +a && cargo run -- up
# docker-compose picks up the repo-root `.env` automatically via `env_file`.

# --- Full RPC URLs per chain (referenced by rpc_url_env in config.toml) ---
# Paste the full URL including any credentials (basic-auth or API-key-in-path).
TIDX_RPC_URL_MODERATO=
TIDX_RPC_URL_MAINNET=

# --- PostgreSQL password (referenced by pg_password_env, if used) ---
# TIDX_PG_PASSWORD=

# --- ClickHouse password (referenced by [chains.clickhouse].password_env, if used) ---
# CH_PASSWORD=
